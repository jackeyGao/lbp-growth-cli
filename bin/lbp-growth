#!/usr/bin/env node

/**
 * LBP Growth CLI - Node.js implementation
 *
 * Agent-friendly CLI for LBP Growth system
 */

const { Command } = require('commander');
const chalk = require('chalk');
const { loadAk, loadCredentials, checkAuth, saveAuth, showAuth } = require('../lib/auth');
const { getEffectiveBearerToken } = require('../lib/config');
const { createPush } = require('../lib/push');
const { listTasks, getTask, listTaskBatches, updateTask, getTaskRealtime, deleteTask, getBlocklist, generateBatchConfirmUrl, downloadTaskRawCsv, downloadTaskFailureCsv, downloadTaskRealtimeClickCsv } = require('../lib/tasks');
const { createBatchUnsendJob, getBatchUnsendStatus } = require('../lib/batch_unsend');
const { syncTeaDaily } = require('../lib/tea');
const { generateReview } = require('../lib/review');
const { splitCSV } = require('../lib/csv');
const pkg = require('../package.json');

const program = new Command();

function outputJSON(data) {
  console.log(JSON.stringify(data, null, 2));
}

function requireAk() {
  const creds = loadCredentials();
  const bearerToken = creds.bearerToken || getEffectiveBearerToken();
  if (!creds.apiKey || !bearerToken) {
    outputJSON({
      ok: false,
      stage: 'auth',
      error: 'NO_CREDENTIALS',
      message: '未配置 API Key 或 Bearer Token，请先执行: lbp-growth auth save <API_KEY> <BEARER_TOKEN>',
    });
    process.exit(2);
  }
  return creds.apiKey;
}

program
  .name('lbp-growth')
  .description('LBP Growth CLI - Agent 友好的推送任务管理工具')
  .version(pkg.version);

// Auth commands
const authCmd = program.command('auth').description('API Key 凭据管理');

authCmd
  .command('check')
  .description('检查本地凭据状态')
  .action(async () => {
    const result = await checkAuth();
    outputJSON(result);
    process.exit(result.ok ? 0 : (result.ak_status === 'missing' ? 2 : 3));
  });

authCmd
  .command('save <apiKey> [bearerToken]')
  .description('保存并校验 API Key 和 Bearer Token')
  .action(async (apiKey, bearerToken) => {
    const result = await saveAuth(apiKey, bearerToken);
    outputJSON(result);
    process.exit(result.ok ? 0 : 3);
  });

authCmd
  .command('show')
  .description('显示当前配置的 API Key（脱敏）')
  .action(() => {
    const result = showAuth();
    outputJSON(result);
    process.exit(result.ok ? 0 : 2);
  });

// Push command
program
  .command('push')
  .description('创建推送任务')
  .requiredOption('--name <name>', '推送任务名称')
  .requiredOption('--format <format>', '推送格式 (card|releaseNote)')
  .option('--content <content>', '卡片内容（format=card 时必填）')
  .option('--release-note-ids <ids>', 'Release Note ID 列表，逗号分隔')
  .option('--apps <apps>', 'app_id 列表，逗号分隔（与 --csv 二选一）')
  .option('--csv <path>', 'CSV 文件路径')
  .option('--schedule-type <type>', '调度类型 (immediate|scheduled)', 'immediate')
  .option('--schedule-time <time>', '定时时间（ISO 格式）')
  .option('--confirm', '确认执行真实推送', false)
  .option('--no-strict-limits', '放行 CSV 超过限制')
  .action(async (options) => {
    const ak = requireAk();
    const result = await createPush({
      ak,
      name: options.name,
      formatType: options.format,
      content: options.content,
      releaseNoteIds: options.releaseNoteIds,
      apps: options.apps,
      csvPath: options.csv,
      scheduleType: options.scheduleType,
      scheduleTime: options.scheduleTime,
      strictLimits: options.strictLimits,
      confirm: options.confirm,
    });
    outputJSON(result);
    process.exit(result.ok ? 0 : (result.stage === 'args' ? 1 : 4));
  });

// Tasks commands
const tasksCmd = program.command('tasks').description('推送任务管理');

tasksCmd
  .command('list')
  .description('查询推送任务列表')
  .option('--day <day>', '查询日期（YYYY-MM-DD）')
  .option('--page <n>', '页码', '1')
  .option('--page-size <n>', '每页数量', '20')
  .action(async (options) => {
    const ak = requireAk();
    const result = await listTasks(ak, {
      day: options.day,
      page: parseInt(options.page),
      pageSize: parseInt(options.pageSize),
    });
    outputJSON(result);
    process.exit(result.ok ? 0 : 4);
  });

tasksCmd
  .command('get <taskId>')
  .description('获取任务详情')
  .action(async (taskId) => {
    const ak = requireAk();
    const result = await getTask(ak, taskId);
    outputJSON(result);
    process.exit(result.ok ? 0 : 4);
  });

tasksCmd
  .command('batches <taskId>')
  .description('获取任务批次列表')
  .option('--page <n>', '页码', '1')
  .option('--page-size <n>', '每页数量', '20')
  .action(async (taskId, options) => {
    const ak = requireAk();
    const result = await listTaskBatches(ak, taskId, {
      page: parseInt(options.page),
      pageSize: parseInt(options.pageSize),
    });
    outputJSON(result);
    process.exit(result.ok ? 0 : 4);
  });

tasksCmd
  .command('update <taskId>')
  .description('更新任务指标')
  .option('--push-count <n>', '推送次数', parseInt)
  .option('--read-count <n>', '阅读次数', parseInt)
  .option('--click-count <n>', '点击次数', parseInt)
  .option('--read-rate <n>', '阅读率', parseFloat)
  .option('--action-rate <n>', '行动率', parseFloat)
  .option('--overall-rate <n>', '综合率', parseFloat)
  .action(async (taskId, options) => {
    const ak = requireAk();
    const result = await updateTask(ak, taskId, options);
    outputJSON(result);
    process.exit(result.ok ? 0 : 4);
  });

tasksCmd
  .command('delete <taskId>')
  .description('删除草稿状态的任务')
  .option('--confirm', '确认删除', false)
  .action(async (taskId, options) => {
    const ak = requireAk();
    const result = await deleteTask(ak, taskId, options.confirm);
    outputJSON(result);
    process.exit(result.ok ? 0 : 4);
  });

tasksCmd
  .command('realtime <taskId>')
  .description('获取任务实时指标')
  .action(async (taskId) => {
    const ak = requireAk();
    const result = await getTaskRealtime(ak, taskId);
    outputJSON(result);
    process.exit(result.ok ? 0 : 4);
  });

tasksCmd
  .command('batch-confirm <taskIds...>')
  .description('生成批量确认草稿任务的 URL（支持 1-20 个 taskId）')
  .action(async (taskIds) => {
    const result = generateBatchConfirmUrl(taskIds);
    outputJSON(result);

    if (result.ok) {
      console.error('\n' + chalk.yellow('⚠️  提醒：'));
      console.error(chalk.cyan('请在浏览器中打开以下链接进行批量确认：'));
      console.error(chalk.underline(result.url));
      console.error('\n' + chalk.gray('注意：'));
      result.rules.forEach(rule => {
        console.error(chalk.gray('  • ' + rule));
      });
    }

    process.exit(result.ok ? 0 : 1);
  });

tasksCmd
  .command('csv-raw <taskId>')
  .description('下载任务原始 AppID 列表 CSV')
  .requiredOption('-o, --output <file>', '输出文件路径')
  .action(async (taskId, options) => {
    const ak = requireAk();
    const result = await downloadTaskRawCsv(ak, taskId, options.output);
    outputJSON(result);
    process.exit(result.ok ? 0 : 4);
  });

tasksCmd
  .command('csv-failure <taskId>')
  .description('下载任务失败 AppID 列表 CSV')
  .requiredOption('-o, --output <file>', '输出文件路径')
  .action(async (taskId, options) => {
    const ak = requireAk();
    const result = await downloadTaskFailureCsv(ak, taskId, options.output);
    outputJSON(result);
    process.exit(result.ok ? 0 : 4);
  });

tasksCmd
  .command('csv-realtime-click <taskId>')
  .description('下载任务实时点击 AppID 列表 CSV')
  .requiredOption('-o, --output <file>', '输出文件路径')
  .action(async (taskId, options) => {
    const ak = requireAk();
    const result = await downloadTaskRealtimeClickCsv(ak, taskId, options.output);
    outputJSON(result);
    process.exit(result.ok ? 0 : 4);
  });

tasksCmd
  .command('unsend <taskId>')
  .description('撤回任务消息（CSV 批量输入，自动分片并发执行，支持断点续传）')
  .requiredOption('--csv <file>', 'app_id CSV 文件路径')
  .option('--concurrency <n>', '并发 worker 数', '3')
  .option('--confirm', '确认执行真实撤回', false)
  .action(async (taskId, options) => {
    const ak = requireAk();
    const result = await createBatchUnsendJob(
      ak,
      taskId,
      options.csv,
      parseInt(options.concurrency, 10),
      options.confirm
    );
    outputJSON(result);
    process.exit(result.ok ? 0 : 4);
  });

tasksCmd
  .command('unsend-status <taskId>')
  .description('查看批量撤回任务进度及每批执行情况')
  .option('--detail', '展示每批 app_ids 和接口返回详情', false)
  .action(async (taskId, options) => {
    const result = getBatchUnsendStatus(taskId, options.detail);
    outputJSON(result);
    process.exit(result.ok ? 0 : 4);
  });

// TEA commands
const teaCmd = program.command('tea').description('TEA 数据同步');

teaCmd
  .command('daily')
  .description('同步 TEA 平台预创建激活链接每日点击数据（仅 super_admin）')
  .requiredOption('--date <date>', '日期（YYYY-MM-DD）')
  .requiredOption('--open-from <openFrom>', '预创建激活链接标识')
  .requiredOption('--pv <n>', '激活点击次数', (value) => parseInt(value, 10))
  .action(async (options) => {
    const ak = requireAk();
    const result = await syncTeaDaily(ak, {
      date: options.date,
      openFrom: options.openFrom,
      pv: options.pv,
    });
    outputJSON(result);
    process.exit(result.ok ? 0 : (result.stage === 'args' ? 1 : 4));
  });

// CSV commands
const csvCmd = program.command('csv').description('CSV 处理工具');

csvCmd
  .command('split <input>')
  .description('拆分大 CSV 文件')
  .option('--out-dir <dir>', '输出目录')
  .option('--rows-per-file <n>', '每文件行数上限', '150000')
  .option('--prefix <prefix>', '分片文件名前缀', 'part')
  .action((input, options) => {
    const result = splitCSV(
      input,
      options.outDir,
      parseInt(options.rowsPerFile),
      options.prefix
    );
    outputJSON(result);
    process.exit(result.ok ? 0 : 1);
  });

// Review command
program
  .command('review')
  .description('生成单日推送数据复盘报告')
  .option('--day <day>', '复盘日期（YYYY-MM-DD，默认昨天）')
  .option('--page-size <n>', '分页大小', '200')
  .action(async (options) => {
    const ak = requireAk();
    const result = await generateReview(ak, options.day, parseInt(options.pageSize));

    if (result.ok) {
      console.log(result.reportMd);
    } else {
      outputJSON(result);
    }
    process.exit(result.ok ? 0 : 4);
  });

// Blocklist command
program
  .command('blocklist')
  .description('获取退订用户黑名单')
  .option('-o, --output <file>', '输出到文件路径（JSON 格式）')
  .action(async (options) => {
    const ak = requireAk();
    const result = await getBlocklist(ak, options.output);
    outputJSON(result);
    process.exit(result.ok ? 0 : 4);
  });

program.parse();

if (!process.argv.slice(2).length) {
  program.outputHelp();
}
